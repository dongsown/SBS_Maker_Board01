<Window x:Class="AtlasDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="Atlas Dashboard"
        Height="780" Width="1340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBgBrush}">

    <!-- ╔══════════════════════════════════════════════════════════╗
         ║  ROOT GRID: Sidebar | Main                              ║
         ╚══════════════════════════════════════════════════════════╝ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════
             COL 0 — SIDEBAR NAVIGATION
        ══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}"
                Padding="16,24,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO + APP NAME -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,0,32">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="#050505" Margin="0,0,10,0">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Atlas" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- MENU LABEL -->
                <TextBlock Grid.Row="1" Text="M E N U" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="14,0,0,10"/>

                <!-- NAV ITEMS -->
                <StackPanel Grid.Row="2">
                    <RadioButton x:Name="NavDashboard"
                                 Style="{StaticResource NavItemStyle}"
                                 IsChecked="True"
                                 Checked="NavMenu_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="16" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavDatabases"
                                 Style="{StaticResource NavItemStyle}"
                                 Checked="NavMenu_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊡" FontSize="16" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Databases" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- BOTTOM: Version tag -->
                <TextBlock Grid.Row="3" Text="v0.1.0-alpha"
                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             COL 1 — MAIN CONTENT AREA
        ══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>    <!-- Row 0: Top Header -->
                <RowDefinition Height="1.2*"/>   <!-- Row 1: Top Widgets -->
                <RowDefinition Height="1*"/>     <!-- Row 2: Bottom Widgets -->
                <RowDefinition Height="Auto"/>   <!-- Row 3: Footer -->
            </Grid.RowDefinitions>

            <!-- ─────────────────────────────────────────────────
                 ROW 0: GLOBAL TOP HEADER
            ───────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="24,20,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Greeting -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Hi, Operator" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TodayDateText"
                               Text="Thursday, 29 May 2026"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style x:Key="RectButtonBlack" TargetType="Button" BasedOn="{StaticResource PillButtonBlack}">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="#111111"
                                                BorderBrush="#111111" BorderThickness="1.5"
                                                CornerRadius="4"
                                                Padding="16,7">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#333333"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>
                    <Button x:Name="BtnNewSession"
        Margin="0,0,10,0"
        Style="{StaticResource RectButtonBlack}">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock Text="＋" Foreground="White" FontSize="14" Margin="0,0,4,0"/>
        <TextBlock Text="New session" Foreground="White" FontSize="14"/>
    </StackPanel>
</Button>
                    <Button x:Name="BtnNotifications"
                            Style="{StaticResource CircleIconButton}"
                            Margin="0,0,10,0"
                            ToolTip="Notifications">
                        <TextBlock Text="🔔" FontSize="15" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnUserProfile"
                            Style="{StaticResource CircleIconButton}"
                            ToolTip="User profile">
                        <TextBlock Text="👤" FontSize="15" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ─────────────────────────────────────────────────
                 ROW 1: TOP WIDGETS (65% / 35%)
            ───────────────────────────────────────────────── -->
            <Grid x:Name="DashboardTopWidgets" Grid.Row="1" Margin="24,0,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6.5*"/>
                    <ColumnDefinition Width="3.5*"/>
                </Grid.ColumnDefinitions>

                <!-- ╌╌ CARD: System View (3D Placeholder) ╌╌ -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardLightBgBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Margin="0,0,10,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Section Tag -->
                        <TextBlock Grid.Row="0" Text="M O T O R   C O N T R O L"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <!-- Subtitle -->
                        <TextBlock Grid.Row="1" Text="Motor Status &amp; 3D Model"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,16"/>

                        <!-- 50% - 50% Split -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: Motor Controls and Start/Stop -->
                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 4 Motor Boxes (Shrunk) -->
                                <UniformGrid Grid.Row="0" Columns="2" Rows="2" Margin="0,0,0,16">

                                    <!-- Motor 1 (Water Pump 1) -->
                                    <Border Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="12" Margin="4" Padding="12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.03"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/> <!-- Animation area -->
                                                <RowDefinition Height="Auto"/> <!-- Title & Controls -->
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Art Area -->
                                            <Border Grid.Row="0" CornerRadius="8" Background="#F0F9FF" ClipToBounds="True" Margin="0,0,0,12">
                                                <Path x:Name="WaterFlow1" Stroke="#38BDF8" StrokeThickness="4" StrokeDashArray="4 4" Stretch="Fill"
                                                      Data="M0,30 Q25,10 50,30 T100,50 150,30 T200,30" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Title & Controls -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Left: Controls -->
                                                <StackPanel x:Name="Motor1Controls" Grid.Column="0" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                                    <RadioButton x:Name="BtnMotor1On" GroupName="Motor1Grp" Style="{StaticResource MotorCircleToggle}" Background="#10B981" ToolTip="ON"/>
                                                    <RadioButton x:Name="BtnMotor1Off" GroupName="Motor1Grp" Style="{StaticResource MotorCircleToggle}" Background="#EF4444" ToolTip="OFF" IsChecked="True"/>
                                                </StackPanel>
                                                <!-- Status Badge for Auto Mode -->
                                                <Border x:Name="Motor1Status" Grid.Column="0" CornerRadius="4" Padding="4,2" Background="#F1F5F9" HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <TextBlock x:Name="Motor1StatusText" Text="OFF" FontSize="8" FontWeight="Bold" Foreground="#94A3B8"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Motor 2 (Water Pump 2) -->
                                    <Border Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="12" Margin="4" Padding="12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.03"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/> <!-- Animation area -->
                                                <RowDefinition Height="Auto"/> <!-- Title & Controls -->
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Art Area -->
                                            <Border Grid.Row="0" CornerRadius="8" Background="#F0F9FF" ClipToBounds="True" Margin="0,0,0,12">
                                                <Path x:Name="WaterFlow2" Stroke="#38BDF8" StrokeThickness="4" StrokeDashArray="4 4" Stretch="Fill"
                                                      Data="M0,30 Q25,50 50,30 T100,10 150,30 T200,30" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Title & Controls -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Left: Controls -->
                                                <StackPanel x:Name="Motor2Controls" Grid.Column="0" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                                    <RadioButton x:Name="BtnMotor2On" GroupName="Motor2Grp" Style="{StaticResource MotorCircleToggle}" Background="#10B981" ToolTip="ON"/>
                                                    <RadioButton x:Name="BtnMotor2Off" GroupName="Motor2Grp" Style="{StaticResource MotorCircleToggle}" Background="#EF4444" ToolTip="OFF" IsChecked="True"/>
                                                </StackPanel>
                                                <!-- Status Badge for Auto Mode -->
                                                <Border x:Name="Motor2Status" Grid.Column="0" CornerRadius="4" Padding="4,2" Background="#F1F5F9" HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <TextBlock x:Name="Motor2StatusText" Text="OFF" FontSize="8" FontWeight="Bold" Foreground="#94A3B8"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Motor 3 (Stirrer 1) -->
                                    <Border Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="12" Margin="4" Padding="12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.03"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/> <!-- Animation area -->
                                                <RowDefinition Height="Auto"/> <!-- Title & Controls -->
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Art Area -->
                                            <Border Grid.Row="0" CornerRadius="8" Background="#F8FAFC" ClipToBounds="True" Margin="0,0,0,12">
                                                <TextBlock x:Name="FanIcon3" Text="❉" FontSize="42" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Border>

                                            <!-- Title & Controls -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Left: Controls -->
                                                <StackPanel x:Name="Motor3Controls" Grid.Column="0" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                                    <RadioButton x:Name="BtnMotor3On" GroupName="Motor3Grp" Style="{StaticResource MotorCircleToggle}" Background="#10B981" ToolTip="ON"/>
                                                    <RadioButton x:Name="BtnMotor3Off" GroupName="Motor3Grp" Style="{StaticResource MotorCircleToggle}" Background="#EF4444" ToolTip="OFF" IsChecked="True"/>
                                                </StackPanel>
                                                <!-- Status Badge for Auto Mode -->
                                                <Border x:Name="Motor3Status" Grid.Column="0" CornerRadius="4" Padding="4,2" Background="#F1F5F9" HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <TextBlock x:Name="Motor3StatusText" Text="OFF" FontSize="8" FontWeight="Bold" Foreground="#94A3B8"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Motor 4 (Stirrer 2) -->
                                    <Border Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="12" Margin="4" Padding="12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.03"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/> <!-- Animation area -->
                                                <RowDefinition Height="Auto"/> <!-- Title & Controls -->
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Art Area -->
                                            <Border Grid.Row="0" CornerRadius="8" Background="#F8FAFC" ClipToBounds="True" Margin="0,0,0,12">
                                                <TextBlock x:Name="FanIcon4" Text="❉" FontSize="42" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Border>

                                            <!-- Title & Controls -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Left: Controls -->
                                                <StackPanel x:Name="Motor4Controls" Grid.Column="0" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                                    <RadioButton x:Name="BtnMotor4On" GroupName="Motor4Grp" Style="{StaticResource MotorCircleToggle}" Background="#10B981" ToolTip="ON"/>
                                                    <RadioButton x:Name="BtnMotor4Off" GroupName="Motor4Grp" Style="{StaticResource MotorCircleToggle}" Background="#EF4444" ToolTip="OFF" IsChecked="True"/>
                                                </StackPanel>
                                                <!-- Status Badge for Auto Mode -->
                                                <Border x:Name="Motor4Status" Grid.Column="0" CornerRadius="4" Padding="4,2" Background="#F1F5F9" HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <TextBlock x:Name="Motor4StatusText" Text="OFF" FontSize="8" FontWeight="Bold" Foreground="#94A3B8"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                </UniformGrid>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <StackPanel.Resources>
                                        <Style x:Key="RectButtonGreen" TargetType="Button" BasedOn="{StaticResource PillButtonGreen}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent"
                                                                BorderBrush="#10B981" BorderThickness="1.5"
                                                                CornerRadius="4"
                                                                Padding="12,4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#1A10B981"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <Style x:Key="RectButtonRed" TargetType="Button" BasedOn="{StaticResource PillButtonRed}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent"
                                                                BorderBrush="#EF4444" BorderThickness="1.5"
                                                                CornerRadius="4"
                                                                Padding="12,4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#1AEF4444"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </StackPanel.Resources>
                                    <Button x:Name="BtnStart"
                                            Content="START"
                                            FontSize="10"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource RectButtonGreen}"/>
                                    <Button x:Name="BtnStop"
                                            Content="STOP"
                                            FontSize="10"
                                            Style="{StaticResource RectButtonRed}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Right Side: 3D Model WebView -->
                            <Border Grid.Column="1"
                                    BorderBrush="#D0D0D0" BorderThickness="1.5"
                                    CornerRadius="12" Background="#FAFAFA">
                                <wv2:WebView2 x:Name="WebView3D" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ╌╌ CARD: Primary Readout / LCD Display ╌╌ -->
                <Border Grid.Column="1"
                        Background="{StaticResource CardDarkBgBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Margin="10,0,0,0" Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Section Tag -->
                        <TextBlock Grid.Row="0"
                                   Text="PRIMARY READOUT / LCD DISPLAY"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,14"/>

                        <!-- OLED LCD Display Box -->
                        <Border Grid.Row="1"
                                Background="#00bf63"
                                CornerRadius="12" Padding="20"
                                Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" Opacity="0.25" BlurRadius="6"/>
                            </Border.Effect>
                            <TextBlock x:Name="LcdDisplay"
                                       FontFamily="JetBrains Mono, Roboto Mono, Consolas"
                                       FontSize="13" LineHeight="22"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       xml:space="preserve"/>
                        </Border>

                        <!-- Command Input -->
                        <Border Grid.Row="2"
                                Background="White"
                                CornerRadius="6" Padding="8,4"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <TextBox x:Name="LcdCommandInput"
                                     Style="{StaticResource CleanTextBox}"
                                     Background="White"
                                     Foreground="#888888"
                                     Opacity="0.7"
                                     Text="TYPE ANYTHING YOU WANT"
                                     FontFamily="Segoe UI Variable, Segoe UI"
                                     FontSize="12"
                                     GotFocus="LcdInput_GotFocus"
                                     LostFocus="LcdInput_LostFocus"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────────
                 ROW 2: BOTTOM WIDGETS (50% / 50%)
            ───────────────────────────────────────────────── -->
            <Grid x:Name="DashboardBottomWidgets" Grid.Row="2" Margin="24,0,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ╌╌ CARD: Telemetry / Sensors ╌╌ -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardLightBgBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Margin="0,0,10,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="T E L E M E T R Y"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="Sensors  •  4"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="Sensors" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,8,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="|" FontSize="11" Margin="0,0,8,0"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="State" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6.5*"/>
                                <ColumnDefinition Width="3.5*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Zone 1: Sensor List -->
                            <ItemsControl Grid.Column="0" x:Name="SensorList"
                                          ItemsSource="{Binding Sensors}"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,18" Opacity="{Binding Opacity}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon -->
                                            <Border Width="28" Height="28" CornerRadius="8"
                                                    Background="{Binding IconBackground}">
                                                <TextBlock Text="{Binding Icon}" FontSize="14"
                                                           Foreground="{Binding IconColor}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Name, Status, Description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <!-- Status Badge -->
                                                    <Border CornerRadius="12" Padding="8,2"
                                                            Background="{Binding StatusBadgeColor}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding StatusForegroundColor}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Zone 2: Auto / Manual Buttons & Cycles Input -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                
                                <!-- Display Box -->
                                <Border x:Name="DisplayCyclesBorder"
                                        Background="{StaticResource CardDarkBgBrush}" 
                                        CornerRadius="12" Padding="10" Margin="0,0,0,10"
                                        Width="120" Height="50"
                                        HorizontalAlignment="Center">
                                    <Viewbox Stretch="Uniform">
                                        <TextBlock x:Name="DisplayCyclesText"
                                                   Text="0"
                                                   FontFamily="JetBrains Mono, Roboto Mono, Consolas"
                                                   Foreground="{StaticResource OledGreenBrush}"
                                                   FontWeight="Bold"/>
                                    </Viewbox>
                                </Border>

                                <!-- Input Label & TextBox -->
                                <TextBlock Text="Enter the number of cycles" FontSize="11" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" 
                                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Border x:Name="InputCyclesBorder" Background="White" CornerRadius="6" BorderThickness="1" BorderBrush="#E0E0E0" Width="90" Margin="0,0,0,24">
                                    <TextBox x:Name="InputCycles"
                                             Style="{StaticResource CleanTextBox}"
                                             Background="Transparent"
                                             Foreground="#333333"
                                             Text="0"
                                             FontSize="14" FontWeight="Bold"
                                             Padding="0" Height="28"
                                             KeyDown="InputCycles_KeyDown"/>
                                </Border>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnAuto"
                                            Content="Manual"
                                            Width="70" Height="28"
                                            FontSize="11" FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="#10B981"
                                            BorderThickness="0"
                                            Margin="0,0,10,0"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="14" Padding="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnManual"
                                            Content="Auto"
                                            Width="70" Height="28"
                                            FontSize="11" FontWeight="SemiBold"
                                            Foreground="#555555"
                                            Background="#E0E0E0"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="14" Padding="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ╌╌ CARD: Trend / System State Chart ╌╌ -->
                <Border Grid.Column="1"
                        Background="{StaticResource CardLightBgBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Margin="10,0,0,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="T R E N D"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="System State Chart"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <!-- Sensor Selector -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <RadioButton x:Name="ChartBtnSensorA" Content="Chất 1" Tag="a" Style="{StaticResource SensorFilterPill}" IsChecked="True" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="ChartBtnSensorB" Content="Chất 2" Tag="b" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="ChartBtnSensorC" Content="Độ cao" Tag="c" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="ChartBtnSensorD" Content="Nhiệt độ" Tag="d" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                            </StackPanel>
                        </Grid>

                        <!-- Real-time Digital Chart -->
                        <Grid Grid.Row="1">
                            <Border CornerRadius="12" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#203498DB" Offset="0.0"/>
                                        <GradientStop Color="#003498DB" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Real-time Digital Chart -->
                            <Canvas x:Name="ChartCanvas" ClipToBounds="True">
                                <!-- High/Low guide lines -->
                                <Line X1="0" Y1="30" X2="2000" Y2="30" Stroke="#403498DB" StrokeDashArray="4 4" StrokeThickness="1"/>
                                <Line X1="0" Y1="130" X2="2000" Y2="130" Stroke="#4095A5A6" StrokeDashArray="4 4" StrokeThickness="1"/>
                                
                                <TextBlock Text="ON (High)" Canvas.Left="10" Canvas.Top="10" FontSize="9" Foreground="#3498DB" FontWeight="Bold"/>
                                <TextBlock Text="OFF (Low)" Canvas.Left="10" Canvas.Top="140" FontSize="9" Foreground="#95A5A6" FontWeight="Bold"/>

                                <Polyline x:Name="DigitalChartLine" 
                                          Stroke="#3498DB" StrokeThickness="2.5"
                                          StrokeLineJoin="Miter" Opacity="0.9" />
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────────
                 DATABASE VIEW
            ───────────────────────────────────────────────── -->
            <Grid x:Name="DatabaseView" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed">
                <Border Background="{StaticResource CardLightBgBrush}" 
                        CornerRadius="{StaticResource CardCornerRadius}" 
                        Margin="24,0,24,12" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header & Selector -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="D A T A B A S E"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="Event Logs (Session)"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            
                            <!-- Sensor Selector -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <RadioButton x:Name="DbBtnSensorA" Content="Chất 1" Tag="a" Style="{StaticResource SensorFilterPill}" IsChecked="True" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="DbBtnSensorB" Content="Chất 2" Tag="b" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="DbBtnSensorC" Content="Độ cao" Tag="c" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                                <RadioButton x:Name="DbBtnSensorD" Content="Nhiệt độ" Tag="d" Style="{StaticResource SensorFilterPill}" Checked="GlobalSensor_Checked"/>
                            </StackPanel>
                        </Grid>

                        <!-- Modern Log List -->
                        <ListView x:Name="DatabaseEventLog" Grid.Row="1"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemContainerStyle="{StaticResource LogListItemStyle}">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource LogGridViewColumnHeaderStyle}">
                                    <GridViewColumn Header="TIMESTAMP" Width="250">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timestamp}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="STATE" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="12,4" Background="{StaticResource CardLightBgBrush}" BorderBrush="#EAEAEA" BorderThickness="1" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding State}" FontWeight="Bold" FontSize="12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOn}" Value="False">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────────
                 ROW 3: FOOTER STATUS BAR
            ───────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{StaticResource FooterBgBrush}"
                    Padding="24,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Connection info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" Fill="{StaticResource AccentGreenBrush}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="Device: " FontWeight="SemiBold"/>
                            <Run Text="PCB #A41"/>
                            <Run Text="   |   " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="Status: " FontWeight="SemiBold"/>
                            <Run Text="Connected" Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold"/>
                            <Run Text="   |   " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="Port: " FontWeight="SemiBold"/>
                            <Run Text="COM3 (USART/USB-TTL)"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Right: Time & icons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="FooterTimeText"
                                   Text="16:30:33"
                                   FontFamily="JetBrains Mono, Consolas"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,12,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="●" FontSize="8"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             OVERLAY UI (ZIndex 999) - Covers Entire Window
        ══════════════════════════════════════════════════════ -->
        <Grid x:Name="OverlayGrid" Background="#A0000000" Visibility="Collapsed" Panel.ZIndex="999" Grid.ColumnSpan="2">
            
            <!-- Reset Alert Bar -->
            <Border x:Name="ResetAlertBox" Background="#18181B" CornerRadius="16" Height="80"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="24,0,24,24" Visibility="Collapsed"
                    BorderThickness="1" BorderBrush="#333333">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="🔄" FontSize="32" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="HỆ THỐNG ĐÃ BỊ RESET" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Phiên làm việc hiện tại đã bị hủy bỏ." Foreground="#A0A0A0" FontSize="12"/>
                    </StackPanel>
                    
                    <Button Grid.Column="2" x:Name="BtnConfirmReset" Content="Xác nhận" Width="120" Height="36" Background="#10B981" Foreground="White" FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnConfirmReset_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Freeze Alert Bar -->
            <Border x:Name="FreezeAlertBox" Background="#18181B" CornerRadius="16" Height="80"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="24,0,24,24" Visibility="Collapsed"
                    BorderThickness="1" BorderBrush="#EF4444">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="⚠️" FontSize="32" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="HỆ THỐNG BỊ ĐÓNG BĂNG" FontSize="16" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,4"/>
                        <TextBlock Text="Đã phát hiện lỗi ở cảm biến. Vui lòng chờ lệnh reset..." Foreground="#A0A0A0" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
